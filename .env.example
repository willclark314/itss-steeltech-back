FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-secret-key
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
# JWT 有效期（小时），默认 8 小时
JWT_ACCESS_TOKEN_HOURS=8

# 数据库：开发默认 sqlite，文件位于 itss-steeltech-db/datas/steeltech.db
DATABASE_BACKEND=sqlite
SQLITE_DATABASE_PATH=../itss-steeltech-db/datas/steeltech.db
DEFAULT_LOGIN_PASSWORD=123456

# MySQL 连接（DATABASE_BACKEND=mysql 时使用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=itss_steeltech

# 允许的前端地址（CORS）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 联系单 PDF 存储根目录（会自动创建 yyyyMMdd 子目录）
CONTACT_PDF_STORAGE_ROOT=datas/files/contact-pdfs
