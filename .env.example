FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-secret-key
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
# JWT 有效期（小时），默认 8 小时
JWT_ACCESS_TOKEN_HOURS=8

# 数据库连接（统一使用 DATABASE_URL 字符串模式）
# SQLite 本地开发（默认）：
DATABASE_URL=sqlite:///../itss-steeltech-db/datas/steeltech.db
# MySQL 生产环境：
# DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/itss_steeltech?charset=utf8mb4

DEFAULT_LOGIN_PASSWORD=123456

# 允许的前端地址（CORS）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 联系单正文 PDF 存储根目录（会自动创建 yyyyMMdd 子目录）
CONTACT_PDF_STORAGE_ROOT=datas/files/contact-pdfs

# 联系单追加附件存储根目录（保留原始扩展名）
CONTACT_ATTACHMENT_STORAGE_ROOT=datas/files/contact-attachments

# 周例会会议记录扫描件 PDF 存储根目录
WEEKLY_MEETING_SCAN_ROOT=datas/files/weekly-meeting-scans
